/* pages/history/history.wxss */
.container {
  padding: var(--spacing-md);
  padding-bottom: 180rpx;
}

.header {
  margin-bottom: var(--spacing-md);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.record-card {
  padding: var(--spacing-sm) var(--spacing-md);
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.record-confidence {
  font-size: 24rpx;
  color: var(--color-accent);
  font-weight: 600;
}

.record-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}
